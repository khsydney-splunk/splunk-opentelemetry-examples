<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <Button
            android:id="@+id/btnJavaCrash"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Trigger Runtime Crash" />

        <Button
            android:id="@+id/btnNullPointer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Trigger NullPointer Crash" />

        <Button
            android:id="@+id/btnIndexCrash"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Trigger IndexOutOfBounds Crash" />

        <Button
            android:id="@+id/btnStackOverflow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Trigger IllegalStateException Crash" />

        <Button
            android:id="@+id/btnBackgroundCrash"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Trigger Background Thread Crash" />

        <Button
            android:id="@+id/btnMainThreadAnr"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Trigger Main Thread ANR" />

        <Button
            android:id="@+id/btnLockAnr"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Trigger Lock/Wait ANR" />

    </LinearLayout>
</ScrollView>